<Window x:Class="TicTacToe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:TicTacToe.Behaviors"
        xmlns:buttonControls="clr-namespace:TicTacToe.Controls.Buttons"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TicTacToe"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Presentation.ViewModels.MainPage;assembly=Presentation"
        Title="TicTacToe"
        Width="600"
        Height="600"
        MinWidth="500"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">

    <Window.DataContext>
        <Binding Path="MainViewModel"
                 Source="{StaticResource ServiceLocator}" />
    </Window.DataContext>

    <Window.Background>
        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" Opacity="0.8" RadiusX="0.9" RadiusY="0.9">
            <GradientStop Offset="0" Color="#DCEEFF" />
            <GradientStop Offset="0.6" Color="#A8D0FF" />
            <GradientStop Offset="1" Color="#F3F4F6" />
        </RadialGradientBrush>
    </Window.Background>

    <Grid>
        <Border x:Name="ParentContainer"
                Margin="10">
            <Grid behaviors:UniformSizingBehavior.IsBehaviorEnabled="True"
                  behaviors:UniformSizingBehavior.ParentContainer="{Binding ElementName=ParentContainer}">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Rectangle Grid.RowSpan="5"
                           Grid.Column="1"
                           Width="1"
                           Fill="LightGray" />

                <Rectangle Grid.RowSpan="5"
                           Grid.Column="3"
                           Width="1"
                           Fill="LightGray" />

                <Rectangle Grid.Row="1"
                           Grid.ColumnSpan="5"
                           Height="1"
                           Fill="LightGray" />

                <Rectangle Grid.Row="3"
                           Grid.ColumnSpan="5"
                           Height="1"
                           Fill="LightGray" />

                <buttonControls:TicTacToeButton Grid.Row="0"
                                                Grid.Column="0"
                                                ButtonRadius="{StaticResource TopLeftTicTacToeCornerRadius}"
                                                Command="{Binding MainViewModel.ChangeCellStateCommand, Source={StaticResource ServiceLocator}}"
                                                CommandParameter="{StaticResource TopLeft}"
                                                DataContext="{Binding Cells, Converter={StaticResource CollectionIndexToElementConverter}, ConverterParameter=0}"
                                                PathGeometryContent="{Binding State, Converter={StaticResource CellStateToIconConverter}}" />
                <buttonControls:TicTacToeButton Grid.Row="0"
                                                Grid.Column="2"
                                                Command="{Binding MainViewModel.ChangeCellStateCommand, Source={StaticResource ServiceLocator}}"
                                                CommandParameter="{StaticResource TopCenter}"
                                                DataContext="{Binding Cells, Converter={StaticResource CollectionIndexToElementConverter}, ConverterParameter=1}"
                                                PathGeometryContent="{Binding State, Converter={StaticResource CellStateToIconConverter}}" />
                <buttonControls:TicTacToeButton Grid.Row="0"
                                                Grid.Column="4"
                                                ButtonRadius="{StaticResource TopRightTicTacToeCornerRadius}"
                                                Command="{Binding MainViewModel.ChangeCellStateCommand, Source={StaticResource ServiceLocator}}"
                                                CommandParameter="{StaticResource TopRight}"
                                                DataContext="{Binding Cells, Converter={StaticResource CollectionIndexToElementConverter}, ConverterParameter=2}"
                                                PathGeometryContent="{Binding State, Converter={StaticResource CellStateToIconConverter}}" />
                <buttonControls:TicTacToeButton Grid.Row="2"
                                                Grid.Column="0"
                                                Command="{Binding MainViewModel.ChangeCellStateCommand, Source={StaticResource ServiceLocator}}"
                                                CommandParameter="{StaticResource CenterLeft}"
                                                DataContext="{Binding Cells, Converter={StaticResource CollectionIndexToElementConverter}, ConverterParameter=3}"
                                                PathGeometryContent="{Binding State, Converter={StaticResource CellStateToIconConverter}}" />
                <buttonControls:TicTacToeButton Grid.Row="2"
                                                Grid.Column="2"
                                                Command="{Binding MainViewModel.ChangeCellStateCommand, Source={StaticResource ServiceLocator}}"
                                                CommandParameter="{StaticResource Center}"
                                                DataContext="{Binding Cells, Converter={StaticResource CollectionIndexToElementConverter}, ConverterParameter=4}"
                                                PathGeometryContent="{Binding State, Converter={StaticResource CellStateToIconConverter}}" />
                <buttonControls:TicTacToeButton Grid.Row="2"
                                                Grid.Column="4"
                                                Command="{Binding MainViewModel.ChangeCellStateCommand, Source={StaticResource ServiceLocator}}"
                                                CommandParameter="{StaticResource CenterRight}"
                                                DataContext="{Binding Cells, Converter={StaticResource CollectionIndexToElementConverter}, ConverterParameter=5}"
                                                PathGeometryContent="{Binding State, Converter={StaticResource CellStateToIconConverter}}" />
                <buttonControls:TicTacToeButton Grid.Row="4"
                                                Grid.Column="0"
                                                ButtonRadius="{StaticResource BottomLeftTicTacToeCornerRadius}"
                                                Command="{Binding MainViewModel.ChangeCellStateCommand, Source={StaticResource ServiceLocator}}"
                                                CommandParameter="{StaticResource BottomLeft}"
                                                DataContext="{Binding Cells, Converter={StaticResource CollectionIndexToElementConverter}, ConverterParameter=6}"
                                                PathGeometryContent="{Binding State, Converter={StaticResource CellStateToIconConverter}}" />
                <buttonControls:TicTacToeButton Grid.Row="4"
                                                Grid.Column="2"
                                                Command="{Binding MainViewModel.ChangeCellStateCommand, Source={StaticResource ServiceLocator}}"
                                                CommandParameter="{StaticResource BottomCenter}"
                                                DataContext="{Binding Cells, Converter={StaticResource CollectionIndexToElementConverter}, ConverterParameter=7}"
                                                PathGeometryContent="{Binding State, Converter={StaticResource CellStateToIconConverter}}" />
                <buttonControls:TicTacToeButton Grid.Row="4"
                                                Grid.Column="4"
                                                ButtonRadius="{StaticResource BottomRightTicTacToeCornerRadius}"
                                                Command="{Binding MainViewModel.ChangeCellStateCommand, Source={StaticResource ServiceLocator}}"
                                                CommandParameter="{StaticResource BottomRight}"
                                                DataContext="{Binding Cells, Converter={StaticResource CollectionIndexToElementConverter}, ConverterParameter=8}"
                                                PathGeometryContent="{Binding State, Converter={StaticResource CellStateToIconConverter}}" />
            </Grid>
        </Border>
    </Grid>
</Window>
