<Application x:Class="TicTacToe.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:Core.Services;assembly=Core"
             xmlns:local="clr-namespace:TicTacToe">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/UiConstants.xaml" />
                <ResourceDictionary Source="Styles/Icons.xaml" />
                <ResourceDictionary Source="Styles/Converters.xaml" />
                <ResourceDictionary Source="Styles/GrouptedRetemplatedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <core:ServiceLocator x:Key="ServiceLocator" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
